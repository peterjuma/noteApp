{
  "short_name": "NoteApp",
  "name": "NoteApp - Markdown Notes",
  "description": "A serverless, lightweight markdown note-taking app with Mermaid diagrams, multiple workspaces, and image support.",
  "start_url": "/noteApp/",
  "scope": "/noteApp/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "theme_color": "#2563eb",
  "background_color": "#ffffff",
  "orientation": "any",
  "categories": ["productivity", "utilities"],
  "icons": [
    {
      "src": "favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    },
    {
      "src": "icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Note",
      "short_name": "New",
      "description": "Create a new markdown note",
      "url": "/noteApp/?action=new",
      "icons": [{ "src": "icon-192.svg", "sizes": "192x192" }]
    },
    {
      "name": "Search Notes",
      "short_name": "Search",
      "description": "Search through your notes",
      "url": "/noteApp/?action=search",
      "icons": [{ "src": "icon-192.svg", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/noteApp/?action=share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/noteApp/?action=open",
      "accept": {
        "text/markdown": [".md", ".markdown", ".mdown", ".mkd"],
        "text/plain": [".txt"]
      }
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "focus-existing"
  }
}
